# ---- Supabase ----
# Project URL: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# anon (public) key — only used for the read-only realtime "ping" channel
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — SERVER ONLY, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# ---- App auth ----
# The shared team PIN (4-6 digits). Change it here to change it for everyone.
APP_PIN=1234
# Random secret for signing the auth cookie. Generate: openssl rand -hex 32
AUTH_COOKIE_SECRET=

# ---- Web Push (VAPID) ----
# Generate a pair with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# private key: keep server-side; also set it as a Supabase edge function secret
VAPID_PRIVATE_KEY=
